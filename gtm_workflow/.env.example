# Copy to .env and fill in. On the deployed host, set these as environment variables.

# ── Lead data provider ──
DATA_PROVIDER=hunter                 # hunter | apollo
HUNTER_API_KEY=your_hunter_api_key   # hunter.io → API (free 50/mo)
APOLLO_API_KEY=your_apollo_api_key   # apollo.io → Settings → Integrations → API (paid plan)

# ── Email (SMTP/IMAP) — sending + reply/bounce detection ──
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=info@aashishagency.com
SMTP_PASS=your_google_app_password   # Google App Password (not the account password)
FROM_NAME=Aashish Agency
IMAP_HOST=imap.gmail.com
IMAP_PORT=993

# ── App ──
APP_BASE_URL=http://localhost:5000   # the public URL once deployed
SECRET_KEY=change-this-to-a-random-string
DATABASE_URL=sqlite:///gtm.db        # on the host, a postgres:// URL

# ── Login: "Sign in with Google", limited to specific addresses ──
# Anyone may sign in with Google; only ALLOWED_GOOGLE_EMAILS are let through.
GOOGLE_CLIENT_ID=                     # Google Cloud Console → OAuth client (Web)
GOOGLE_CLIENT_SECRET=
ALLOWED_GOOGLE_EMAILS=info@aashishagency.com,sujit@aashishagency.com
# Fallback password login (used only while Google isn't configured):
APP_USERNAME=
APP_PASSWORD=
